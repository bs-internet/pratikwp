        "display_type": "list",
        "query_type": "and"
      },
      {
        "id": "woocommerce_top_rated_products-1",
        "widget": "woocommerce_top_rated_products",
        "title": "En Çok Beğenilen Ürünler",
        "number": 5
      }
    ],
    "header-1": [
      {
        "id": "text-6",
        "widget": "text",
        "title": "",
        "text": "<div class=\"header-cta text-end\">\n<p class=\"mb-1\"><i class=\"fas fa-phone me-2 text-primary\"></i><strong>+90 (224) 123 45 67</strong></p>\n<p class=\"mb-0 small text-muted\">7/24 Destek Hattı</p>\n</div>",
        "filter": false
      }
    ],
    "offcanvas-1": [
      {
        "id": "text-7",
        "widget": "text",
        "title": "Mobil Menü",
        "text": "<div class=\"mobile-welcome\">\n<p><strong>PratikWP'ye hoş geldiniz!</strong></p>\n<p class=\"small text-muted\">Modern WordPress temanız için her şey burada.</p>\n</div>",
        "filter": false
      }
    ]
  },

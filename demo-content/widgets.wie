{
  "version": "1.0.0",
  "site_url": "https://demo.pratikwp.com",
  "date": "2024-01-01 12:00:00",
  "widgets": {
    "sidebar-1": [
      {
        "id": "text-1",
        "widget": "text",
        "title": "Hakkımızda",
        "text": "<div class=\"widget-about\">\n<p><strong>PratikWP</strong> modern WordPress teması ile web sitenizi profesyonel bir seviyeye taşıyın.</p>\n<p>✨ Elementor uyumlu<br>\n🚀 Hızlı performans<br>\n📱 Responsive tasarım<br>\n🔍 SEO optimize edilmiş</p>\n<p><a href=\"/hakkimizda\" class=\"btn btn-primary btn-sm\">Daha Fazla Bilgi</a></p>\n</div>",
        "filter": false
      },
      {
        "id": "recent-posts-1",
        "widget": "recent-posts",
        "title": "Son Yazılar",
        "number": 5,
        "show_date": true
      },
      {
        "id": "categories-1",
        "widget": "categories",
        "title": "Kategoriler",
        "count": true,
        "hierarchical": false,
        "dropdown": false
      },
      {
        "id": "tag_cloud-1",
        "widget": "tag_cloud",
        "title": "Popüler Etiketler",
        "taxonomy": "post_tag",
        "count": 20
      }
    ],
    "footer-1": [
      {
        "id": "text-2",
        "widget": "text",
        "title": "PratikWP",
        "text": "<div class=\"footer-brand\">\n<p>Modern WordPress teması ile web sitenizi bir üst seviyeye taşıyın. Profesyonel tasarım, hızlı performans ve kullanıcı dostu arayüz.</p>\n<div class=\"footer-contact mt-3\">\n<p><i class=\"fas fa-map-marker-alt me-2\"></i> Nilüfer, Bursa, Türkiye</p>\n<p><i class=\"fas fa-phone me-2\"></i> <a href=\"tel:+902241234567\">+90 (224) 123 45 67</a></p>\n<p><i class=\"fas fa-envelope me-2\"></i> <a href=\"mailto:info@pratikwp.com\">info@pratikwp.com</a></p>\n</div>\n</div>",
        "filter": false
      }
    ],
    "footer-2": [
      {
        "id": "nav_menu-1",
        "widget": "nav_menu",
        "title": "Hızlı Linkler",
        "nav_menu": "Footer Menu"
      },
      {
        "id": "text-3",
        "widget": "text",
        "title": "Hizmetlerimiz",
        "text": "<ul class=\"footer-services list-unstyled\">\n<li><a href=\"/web-tasarim\"><i class=\"fas fa-chevron-right me-2\"></i>Web Tasarım</a></li>\n<li><a href=\"/wordpress-gelistirme\"><i class=\"fas fa-chevron-right me-2\"></i>WordPress Geliştirme</a></li>\n<li><a href=\"/seo-hizmetleri\"><i class=\"fas fa-chevron-right me-2\"></i>SEO Hizmetleri</a></li>\n<li><a href=\"/e-ticaret\"><i class=\"fas fa-chevron-right me-2\"></i>E-Ticaret Çözümleri</a></li>\n<li><a href=\"/hosting\"><i class=\"fas fa-chevron-right me-2\"></i>Hosting & Domain</a></li>\n<li><a href=\"/bakim\"><i class=\"fas fa-chevron-right me-2\"></i>Site Bakım</a></li>\n</ul>",
        "filter": false
      }
    ],
    "footer-3": [
      {
        "id": "recent-posts-2",
        "widget": "recent-posts",
        "title": "Blog Yazıları",
        "number": 4,
        "show_date": true
      }
    ],
    "footer-4": [
      {
        "id": "text-4",
        "widget": "text",
        "title": "Newsletter",
        "text": "<div class=\"newsletter-widget\">\n<p>Güncel haberler, ipuçları ve özel tekliflerden haberdar olun.</p>\n<form class=\"newsletter-form\" method=\"post\" action=\"#\">\n<div class=\"input-group mb-3\">\n<input type=\"email\" class=\"form-control\" placeholder=\"E-posta adresiniz\" required>\n<button class=\"btn btn-primary\" type=\"submit\">\n<i class=\"fas fa-paper-plane\"></i>\n</button>\n</div>\n</form>\n<small class=\"text-muted\">Gizliliğinize saygı duyuyoruz. İstediğiniz zaman abonelikten çıkabilirsiniz.</small>\n</div>",
        "filter": false
      },
      {
        "id": "text-5",
        "widget": "text",
        "title": "Sertifikalarımız",
        "text": "<div class=\"certificates\">\n<div class=\"row g-2\">\n<div class=\"col-6\">\n<img src=\"/wp-content/uploads/2024/01/ssl-certificate.png\" alt=\"SSL Sertifikası\" class=\"img-fluid\">\n</div>\n<div class=\"col-6\">\n<img src=\"/wp-content/uploads/2024/01/google-partner.png\" alt=\"Google Partner\" class=\"img-fluid\">\n</div>\n<div class=\"col-6\">\n<img src=\"/wp-content/uploads/2024/01/wordpress-expert.png\" alt=\"WordPress Expert\" class=\"img-fluid\">\n</div>\n<div class=\"col-6\">\n<img src=\"/wp-content/uploads/2024/01/iso-certificate.png\" alt=\"ISO Sertifikası\" class=\"img-fluid\">\n</div>\n</div>\n</div>",
        "filter": false
      }
    ],
    "shop-sidebar": [
      {
        "id": "woocommerce_product_categories-1",
        "widget": "woocommerce_product_categories",
        "title": "Ürün Kategorileri",
        "count": true,
        "hierarchical": true,
        "show_children_only": false,
        "hide_empty": true
      },
      {
        "id": "woocommerce_price_filter-1",
        "widget": "woocommerce_price_filter",
        "title": "Fiyata Göre Filtrele"
      },
